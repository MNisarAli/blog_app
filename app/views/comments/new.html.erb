<section>
  <h3>Add a comment:</h3>
  <%= form_with model: @comment, url: user_post_comments_path, local: true do |form| %>
    <%= form.label :text, 'Comment' %>
    <%= form.text_field :text, class: "comment_field", placeholder: "Enter a text here" %>
    <%= form.submit "Add comment", class: "submit-btn btn" %>
  <% end %>
</section>