<section>
  <h2>Create a new post:</h2>
  <%= form_with model: @post, url: user_posts_path, method: :post do |form| %>
    <%= form.label :title, 'Title' %>
    <%= form.text_field :title, class: 'form_title', placeholder: 'Enter a title here' %>
    <%= form.label :text, 'Text' %>
    <%= form.text_area :text, class: 'form_text', placeholder: 'Enter a text here' %>
    <%= form.submit 'Post', class: 'submit-btn btn' %>
  <% end %>
</section>